# Required: LLM API Key (choose one based on your llm config)
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# Optional: Additional search providers
# Uncomment and configure in agent-config.yml to enable

# Tavily - AI-powered research search
# TAVILY_API_KEY=your-tavily-api-key

# Perplexity - Real-time AI search
# PERPLEXITY_API_KEY=your-perplexity-api-key

# Firecrawl - Advanced web scraping with semantic search
# FIRECRAWL_API_KEY=your-firecrawl-api-key
